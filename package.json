{
  "name": "@pushary/ai-sdk",
  "version": "0.1.1",
  "description": "Vercel AI SDK tools for Pushary: pause your agent until a real human approves on their phone (human-in-the-loop).",
  "author": "Pushary <business@pushary.com>",
  "homepage": "https://pushary.com/human-in-the-loop-vercel-ai-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pushary/pushary-ai-sdk.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@pushary/server": "^1.3.1"
  },
  "peerDependencies": {
    "ai": ">=5.0.0",
    "zod": ">=3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pushary",
    "vercel-ai-sdk",
    "ai-sdk",
    "ai",
    "human-in-the-loop",
    "hitl",
    "agent",
    "approval",
    "tool",
    "llm"
  ],
  "bugs": {
    "url": "https://github.com/Pushary/pushary-ai-sdk/issues"
  }
}
